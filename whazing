#!/bin/bash

# =========================
# CORES
# =========================
RED='\033[1;31m'
YELLOW='\033[1;33m'
GREEN='\033[1;32m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'

print_banner() {
  printf "${CYAN}${BOLD}========================================${NC}\n"
}

verifica_disco() {
  uso=$(df -h / | awk 'NR==2 {print $5}' | sed 's/%//')

  total=30
  preenchido=$((uso * total / 100))
  vazio=$((total - preenchido))

  barra_cheia=$(printf "%0.s█" $(seq 1 $preenchido))
  barra_vazia=$(printf "%0.s░" $(seq 1 $vazio))

  print_banner
  printf "${BOLD}💾 VERIFICAÇÃO DE DISCO${NC}\n"
  print_banner

  printf "\n${WHITE}Uso atual:${NC} ${BOLD}%s%%${NC}\n\n" "$uso"

  if [ "$uso" -ge 95 ]; then COR=$RED
  elif [ "$uso" -ge 90 ]; then COR=$RED
  elif [ "$uso" -ge 80 ]; then COR=$YELLOW
  else COR=$GREEN
  fi

  printf "${COR}[%s%s] %s%%${NC}\n\n" "$barra_cheia" "$barra_vazia" "$uso"

  if [ "$uso" -ge 95 ]; then
    printf "${RED}${BOLD}❌ BLOQUEADO - DISCO CRÍTICO (>95%)${NC}\n"
    printf "${RED}Libere espaço antes de continuar.${NC}\n"
    exit 1

  elif [ "$uso" -ge 90 ]; then
    printf "${RED}${BOLD}🔴 ALERTA CRÍTICO${NC}\n"
    printf "${RED}Pode falhar durante instalação.${NC}\n"

  elif [ "$uso" -ge 80 ]; then
    printf "${YELLOW}${BOLD}🟡 ATENÇÃO${NC}\n"
    printf "${YELLOW}Espaço baixo.${NC}\n"

  else
    printf "${GREEN}${BOLD}🟢 DISCO OK${NC}\n"
  fi

  printf "\n"
  sleep 5
}

git pull

verifica_disco

# Verifica se o arquivo /etc/os-release existe
if [[ -f /etc/os-release ]]; then
    # Carrega as informações do sistema
    . /etc/os-release
    OS_NAME=$ID
    OS_VERSION=${VERSION_ID//\"/}  # Remove aspas se existirem
else
    echo "Erro: Não foi possível detectar a versão do sistema operacional."
    exit 1
fi

# Verifica se o sistema é Ubuntu e se a versão é compatível
if [[ "$OS_NAME" != "ubuntu" || ("$OS_VERSION" != "20.04" && "$OS_VERSION" != "22.04" && "$OS_VERSION" != "24.04") ]]; then
    echo "Erro: Este script só pode ser executado no Ubuntu 20.04 ou 22.04 ou 24.04"
    echo "Sistema detectado: $OS_NAME $OS_VERSION"
    exit 1
fi

echo "Sistema compatível detectado: $OS_NAME $OS_VERSION"
echo "Continuando instalador..."
sleep 1

# =========================
# VALIDAÇÃO DE ARQUITETURA
# =========================
ARCH=$(uname -m)

echo "Arquitetura detectada: $ARCH"

if [[ "$ARCH" != "x86_64" && "$ARCH" != "amd64" ]]; then
  echo -e "${RED}${BOLD}❌ ARQUITETURA NÃO SUPORTADA${NC}"
  echo -e "${RED}Este sistema NÃO funciona em ARM (aarch64, arm64, etc).${NC}"
  echo -e "${YELLOW}Use uma VPS com arquitetura x86_64.${NC}"
  exit 1
fi

echo -e "${GREEN}✅ Arquitetura compatível (x86_64)${NC}\n"
sleep 2

# Verifica se o sistema está aguardando reinicialização
if [ -f /var/run/reboot-required ]; then
    echo "⚠️  O sistema precisa ser reiniciado antes de executar este script."
    echo "❌ Saindo..."
    exit 1
fi

echo "✅ Nenhuma reinicialização pendente. Continuando a execução..."

# reset shell colors
tput init

# https://stackoverflow.com/questions/59895/how-to-get-the-source-directory-of-a-bash-script-from-within-the-script-itself
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do # resolve $SOURCE until the file is no longer a symlink
  PROJECT_ROOT="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$PROJECT_ROOT/$SOURCE" # if $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
done
PROJECT_ROOT="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

# required imports
source "${PROJECT_ROOT}"/variables/manifest.sh
source "${PROJECT_ROOT}"/utils/manifest.sh
source "${PROJECT_ROOT}"/lib/manifest.sh

# user configs file
if [[ ! -e "${PROJECT_ROOT}"/config ]]; then
  cat << EOF > "${PROJECT_ROOT}"/config
deploy_password=${senha}
EOF
fi

# this file has passwords
sudo su - root <<EOF
chown root:root "${PROJECT_ROOT}"/config
chmod 700 "${PROJECT_ROOT}"/config
EOF
source "${PROJECT_ROOT}"/config
senha=$(openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 16)

# interactive CLI
inquiry_options

# dependencies related
system_set_timezone
system_puppeteerdocker_dependencies
system_caddy_setup
system_sysctl
system_docker_install
instalacao_firewall

# system config
system_create_user

# backend related
system_set_user_mod
backend_criar_diretorios
system_unzip_logos
backend_set_env
backend_db_create
system_docker_restart

# frontend related
frontend_set_env
download_docker_imagem_estavel
backend_docker_start
frontend_docker_start

# network related
caddy_config_setup
criar_cron
system_success
